{
  "extends": [
    "stylelint-config-standard"
  ],
  "ignoreFiles": [
    "src/index.css",
    "src/App.css"
  ],
  "rules": {
    "declaration-property-value-disallowed-list": {
      "/color$/": [
        "/#(?:[0-9a-fA-F]{3,8})\\b/",
        "/rgba?\\(/",
        "/hsla?\\(/"
      ],
      "fill": [
        "/#(?:[0-9a-fA-F]{3,8})\\b/",
        "/rgba?\\(/",
        "/hsla?\\(/"
      ],
      "stroke": [
        "/#(?:[0-9a-fA-F]{3,8})\\b/",
        "/rgba?\\(/",
        "/hsla?\\(/"
      ]
    }
  }
}
