# Development image for React frontend.
# In ProjectMaker deployments there is no bind-mount, so source is baked
# into the image via COPY. node_modules are installed at build time.

FROM node:22-alpine

WORKDIR /app

# Install dependencies first (layer-cached until package.json changes)
COPY package.json package-lock.json* ./
RUN npm install

# Copy source
COPY . .

CMD ["npm", "start"]
