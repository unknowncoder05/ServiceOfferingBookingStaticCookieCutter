# Development image for React frontend.
# Source is bind-mounted at /app at runtime (from projectmaker.dev.yml volumes).
# Only node_modules are installed at build time and cached in a named volume.

FROM node:22-alpine

WORKDIR /app

# Install dependencies — layer-cached until package.json changes.
# node_modules are preserved by the named volume declared in projectmaker.dev.yml,
# so they survive the ./frontend:/app bind-mount overlay.
COPY package.json package-lock.json* ./
RUN npm install

CMD ["npm", "start"]
